{
  "name": "schelling-points",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "tsx --watch src/server.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx src/server.ts",
    "setup-ollama": "bash scripts/setup-ollama.sh",
    "postinstall": "bash scripts/setup-ollama.sh",
    "cap:build": "VITE_API_HOST=schellingpoints.app vite build && npx cap sync",
    "cap:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.1.0",
    "@capgo/capacitor-updater": "^8.43.9",
    "howler": "^2.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-qrcode-logo": "^4.0.0",
    "react-router": "^7.13.0",
    "react-swipeable": "^7.0.2",
    "stemmer": "^2.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@capgo/cli": "^7.84.2",
    "@types/express": "^5.0.6",
    "@types/express-ws": "^3.0.6",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "tsx": "^4.21.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
